# JARVIS Environment Variables
# Copiar este archivo a .env y ajustar valores

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=jarvis2026

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MCP Server Configuration
MCP_HOST=0.0.0.0
MCP_PORT=8000

# LLM API Keys (poner tus keys reales en .env, NO en este archivo)
OPENCODE_API_KEY=sk-tu-key-aqui
OPENROUTER_API_KEY=sk-or-tu-key-aqui

# GitHub
GH_TOKEN=gho_tu-token-aqui

# ngrok
NGROK_TOKEN=tu-ngrok-token-aqui

# Vercel
VERCEL_TOKEN=vca_tu-vercel-token-aqui

# JARVIS Web UI
JARVIS_WEB_PORT=5678
JARVIS_WEB_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
ALLOWED_COMMANDS=ls,pwd,date,whoami,uptime,docker ps,systemctl status
MAX_COMMAND_TIMEOUT=10

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=24h
BACKUP_PATH=/backups

# Monitoring
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
