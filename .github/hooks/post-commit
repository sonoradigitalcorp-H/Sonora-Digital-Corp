#!/bin/bash
# Post-commit hook: Update CATALOG.md and log events
set -euo pipefail

BASE_DIR="$(git rev-parse --show-toplevel)"
PROCESS_DIR="$BASE_DIR/process"
CATALOG="$PROCESS_DIR/completed/CATALOG.md"

# Check if a spec was completed
latest_completed=$(ls -dt "$PROCESS_DIR/completed/"*/ 2>/dev/null | head -1)
if [ -n "$latest_completed" ]; then
  spec_id=$(basename "$latest_completed")
  date_part="${spec_id:0:8}"
  # Update CATALOG if it doesn't already have this entry
  if ! grep -q "$spec_id" "$CATALOG" 2>/dev/null; then
    echo "| $(date -d "$date_part" +%Y-%m-%d 2>/dev/null || echo "$date_part") | $spec_id | ... | ... | ... | completed | ... |" >> "$CATALOG"
    echo "✓ CATALOG.md updated: $spec_id"
  fi
fi

# Log commit event
events_dir="$BASE_DIR/state/logs"
mkdir -p "$events_dir"
ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
commit_msg=$(git log -1 --pretty=%s)
echo "{\"event\":\"commit\",\"timestamp\":\"$ts\",\"payload\":{\"message\":\"$commit_msg\"}}" >> "$events_dir/events.jsonl"
