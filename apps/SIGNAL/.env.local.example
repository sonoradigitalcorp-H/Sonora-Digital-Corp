# ── SIGNAL Music Intelligence Platform ──
# Provider Ecosystem Configuration
# Copiar a .env.local y configurar según disponibilidad

# ════════════════════════════════════════════════════════════
# PROVIDER MASTER SWITCHES
# ════════════════════════════════════════════════════════════
# Cada provider puede deshabilitarse individualmente.
# Por defecto: todos habilitados (true).

SPOTIFY_PROVIDER_ENABLED=true
DEEZER_PROVIDER_ENABLED=true
YOUTUBE_PROVIDER_ENABLED=true
INSTAGRAM_PROVIDER_ENABLED=true
TIKTOK_PROVIDER_ENABLED=true

# ════════════════════════════════════════════════════════════
# SPOTIFY WEB API (Client Credentials Flow)
# ════════════════════════════════════════════════════════════
# Crear app en: https://developer.spotify.com/dashboard/
# ⚠️ Feb 2026: Spotify requiere cuenta Premium para Development Mode
#
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_CACHE_TTL_HOURS=24
SPOTIFY_REQUEST_TIMEOUT=10000
SPOTIFY_RATE_LIMIT_INTERVAL=200
SPOTIFY_MAX_RETRIES=3
SPOTIFY_TOKEN_BUFFER=300000

# ════════════════════════════════════════════════════════════
# YOUTUBE DATA API v3
# ════════════════════════════════════════════════════════════
# Obtener API Key: https://console.cloud.google.com/apis/credentials
# Habilitar: YouTube Data API v3
# Proporciona: subscribers, views, videos, engagement, upload frequency
#
# Cualquiera de estas dos variables funciona:
GOOGLE_API_KEY=
YOUTUBE_API_KEY=
#
YOUTUBE_CACHE_TTL_HOURS=6
YOUTUBE_REQUEST_TIMEOUT=10000
YOUTUBE_RATE_LIMIT_INTERVAL=300
YOUTUBE_MAX_RETRIES=3

# ════════════════════════════════════════════════════════════
# INSTAGRAM (Meta Graph API)
# ════════════════════════════════════════════════════════════
# Requiere: Facebook App + Instagram Business Account
# https://developers.facebook.com/docs/instagram-api/
#
# Token de acceso de largo plazo (Meta Graph API):
META_ACCESS_TOKEN=
# o alternativamente:
INSTAGRAM_ACCESS_TOKEN=
#
# Instagram Business Account ID (para Business API completo):
INSTAGRAM_BUSINESS_ID=
# o:
IG_BUSINESS_ID=
#
# NOTA: Sin Business ID, el provider funciona en modo Basic API
# (datos limitados — solo profile básico, sin métricas)
#
INSTAGRAM_CACHE_TTL_HOURS=6
INSTAGRAM_REQUEST_TIMEOUT=10000
INSTAGRAM_RATE_LIMIT_INTERVAL=500
INSTAGRAM_MAX_RETRIES=2

# ════════════════════════════════════════════════════════════
# TIKTOK (Official APIs)
# ════════════════════════════════════════════════════════════
# Research API (recomendada):
# https://developers.tiktok.com/products/research-api/
# Solicitar acceso en TikTok for Developers
#
TIKTOK_ACCESS_TOKEN=
#
# Business API (alternativa limitada):
TIKTOK_BUSINESS_TOKEN=
#
# NOTA: Sin credenciales, TikTok provider funciona en modo placeholder
# — no scraping. Retorna datos vacíos gracefulmente.
#
TIKTOK_CACHE_TTL_HOURS=6
TIKTOK_REQUEST_TIMEOUT=10000
TIKTOK_RATE_LIMIT_INTERVAL=500
TIKTOK_MAX_RETRIES=2

# ════════════════════════════════════════════════════════════
# DEEZER API (Pública — no necesita key)
# ════════════════════════════════════════════════════════════
# Funciona sin configuración. Proporciona imágenes de artistas.
# DEEZER_PROVIDER_ENABLED=true  (controlado arriba)

# ════════════════════════════════════════════════════════════
# OPENROUTER (para SIGNAL Assist Chat)
# ════════════════════════════════════════════════════════════
# OPCIONAL — Chat funciona sin esto (responde con knowledge base)
# OPENROUTER_API_KEY=
