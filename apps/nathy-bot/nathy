#!/usr/bin/env python3
"""Nathy CLI — controla el bot, canal, audios y clientes.

Uso:
  nathy post "Mensaje"                    → Postea al canal
  nathy audio "Texto para audio"          → Audio al canal
  nathy summary <user_id>                 → Resumen de cliente
  nathy add-cliente <id> <nombre>         → Nuevo cliente
  nathy add-red <id> <red> <url>          → Red social a cliente
  nathy update-finanzas <id> <ing> <fe> <fr> <isr> <iva> <prox>
                                          → Actualizar finanzas
  nathy list-clientes                     → Listar todos
"""
import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent))

# Map bare commands to --flags
CMD_MAP = {
    "post": "--post",
    "audio": "--audio",
    "summary": "--summary",
    "add-cliente": "--add-cliente",
    "add-red": "--add-red",
    "update-finanzas": "--update-finanzas",
    "list-clientes": "--list-clientes",
}

if len(sys.argv) > 1 and sys.argv[1] in CMD_MAP:
    sys.argv.insert(1, CMD_MAP[sys.argv.pop(1)])

from nathy_bot import cli
cli()
