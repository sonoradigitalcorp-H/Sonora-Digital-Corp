# ── SIGNAL Music Intelligence Platform ──
# Copiar a .env.local y llenar con tus keys reales

# ═══════════════════════════════════════════
# SPOTIFY WEB API (Client Credentials Flow)
# ═══════════════════════════════════════════
# OBLIGATORIO para datos REALES de artistas
# Crear app en: https://developer.spotify.com/dashboard/
# Tipo: Web API (gratuito, sin tarjeta de crédito)
#
# Spotify Client ID (32 chars hex)
SPOTIFY_CLIENT_ID=
# Spotify Client Secret (32 chars hex)
SPOTIFY_CLIENT_SECRET=

# ═══════════════════════════════════════════
# SPOTIFY API — Opcionales
# ═══════════════════════════════════════════

# Market para top tracks (ISO 3166-1 alpha-2 code)
# Default: US
# Para música latina usar: MX, ES, AR, CO
SPOTIFY_MARKET=US

# Cache TTL para datos de artistas (en horas)
# Default: 24 (recommended: 6-48)
SPOTIFY_CACHE_TTL_HOURS=24

# Request timeout en milisegundos
# Default: 10000 (10s)
SPOTIFY_REQUEST_TIMEOUT=10000

# Intervalo mínimo entre requests (ms) — rate limiting
# Default: 200 (Spotify recomienda ~300 req/min)
SPOTIFY_RATE_LIMIT_INTERVAL=200

# Máximo de reintentos en caso de rate limit (429)
# Default: 3 (backoff exponencial: 1s, 2s, 4s + Retry-After)
SPOTIFY_MAX_RETRIES=3

# Buffer de seguridad para expiración del token (ms)
# Default: 300000 (5 min antes de renovar)
SPOTIFY_TOKEN_BUFFER=300000

# ═══════════════════════════════════════════
# OPENROUTER (para SIGNAL Assist Chat)
# ═══════════════════════════════════════════
# OPCIONAL — Chat funciona sin esto (responde con knowledge base)
OPENROUTER_API_KEY=

# ═══════════════════════════════════════════
# NOTAS
# ═══════════════════════════════════════════
# - Deezer API no necesita key (pública)
# - Sin Spotify credentials → app funciona en fallback mode
