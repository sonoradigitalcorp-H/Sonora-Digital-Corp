# ── SIGNAL Music Intelligence Platform ──
# Copiar a .env.local y llenar con tus keys reales

# Spotify Web API (gratis — registrar app en https://developer.spotify.com/dashboard/)
# Necesario para datos REALES de artistas (oyentes, seguidores, popularidad)
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui

# OpenRouter (para SIGNAL Assist chat con LLM real)
OPENROUTER_API_KEY=sk-or-tu-key-aqui

# Deezer API (público — no necesita key)
# Ya funciona con la API pública de Deezer para fotos de artistas
