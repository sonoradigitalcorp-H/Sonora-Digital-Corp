{
  "version": "1.1.0",
  "name": "Sonora Digital Corp Design System — Cálido",
  "colors": {
    "primary": "#c85a3e",
    "primary-hover": "#d46b4f",
    "secondary": "#d4a34a",
    "secondary-hover": "#deb55e",
    "accent": "#e87a30",
    "success": "#4ade80",
    "warning": "#facc15",
    "error": "#ef4444",
    "background": "#120c0a",
    "surface": "rgba(245,230,211,0.04)",
    "surface-hover": "rgba(245,230,211,0.08)",
    "text": "#f5e6d3",
    "text-muted": "rgba(245,230,211,0.55)",
    "text-dim": "rgba(245,230,211,0.3)",
    "border": "rgba(245,230,211,0.08)",
    "border-hover": "rgba(200,90,62,0.3)",
    "bg-card": "rgba(245,230,211,0.03)",
    "bg-surface-alt": "rgba(245,230,211,0.02)"
  },
  "typography": {
    "font-family": "'Inter', system-ui, -apple-system, sans-serif",
    "font-mono": "'JetBrains Mono', 'Fira Code', monospace",
    "weights": { "light": 300, "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "scale": [1, 1.25, 1.563, 1.953, 2.441, 3.052, 3.815],
    "line-height": 1.6
  },
  "spacing": {
    "base": 8,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96, 128]
  },
  "border-radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "full": 9999
  },
  "shadows": {
    "sm": "0 2px 8px rgba(0,0,0,0.5)",
    "md": "0 4px 16px rgba(0,0,0,0.6)",
    "lg": "0 8px 32px rgba(0,0,0,0.7)",
    "glow-primary": "0 0 20px rgba(200,90,62,0.25)",
    "glow-secondary": "0 0 20px rgba(212,163,74,0.2)"
  },
  "transitions": {
    "fast": "0.15s ease",
    "normal": "0.3s ease",
    "slow": "0.5s ease"
  },
  "z-index": {
    "base": 1,
    "dropdown": 10,
    "sticky": 50,
    "fixed": 100,
    "modal": 200,
    "toast": 300
  },
  "breakpoints": {
    "sm": 640,
    "md": 768,
    "lg": 1024,
    "xl": 1280,
    "2xl": 1536
  },
  "components": {
    "card": {
      "background": "rgba(245,230,211,0.03)",
      "border": "1px solid rgba(245,230,211,0.08)",
      "border-radius": 16,
      "padding": 24,
      "hover": { "border-color": "rgba(200,90,62,0.3)", "transform": "translateY(-4px)" }
    },
    "button": {
      "primary": { "background": "linear-gradient(135deg, #c85a3e, #d4a34a)", "color": "#fff" },
      "secondary": { "background": "rgba(245,230,211,0.05)", "border": "1px solid rgba(245,230,211,0.1)", "color": "#f5e6d3" },
      "border-radius": 12,
      "padding": "16px 32px",
      "font-weight": 600
    },
    "input": {
      "background": "rgba(245,230,211,0.05)",
      "border": "1px solid rgba(245,230,211,0.1)",
      "border-radius": 8,
      "padding": "12px 16px",
      "color": "#f5e6d3"
    }
  }
}
