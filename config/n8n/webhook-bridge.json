    {
      "parameters": {
        "url": "http://host.docker.internal:5174/api/webhook/n8n-response",
        "sendBody": true,
        "options": {}
      },
      "id": "get-response",
      "name": "Get Response",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [650, 300]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "respond-to-webhook",
