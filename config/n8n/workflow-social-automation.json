{
  "name": "📱 Caso 3: Red Social Automatizada → Tráfico → Conversión",
  "nodes": [
    {
      "id": "schedule-auto",
      "name": "Schedule (Cada 6 horas)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "rule": {
          "interval": 360
        }
      }
    },
    {
      "id": "fetch-content",
      "name": "Obtener Contenido Nuevo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 300],
      "parameters": {
        "url": "http://host.docker.internal:5174/api/store/featured",
        "method": "GET",
        "options": {}
      }
    },
    {
      "id": "check-new",
      "name": "¿Hay contenido nuevo?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [650, 300],
      "parameters": {
        "conditions": {
          "number": [
            { "value1": "={{ $json.items.length }}", "operation": "larger", "value2": 0 }
          ]
        }
      }
    },
    {
      "id": "preview-generator",
      "name": "Generar Preview (Fal.ai)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [850, 200],
      "parameters": {
        "url": "http://host.docker.internal:5174/api/generate/preview",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "item_id", "value": "={{ $json.items[0].id }}" },
            { "name": "style", "value": "teaser" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "publish-twitter",
      "name": "Publicar en Twitter/X",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1050, 200],
      "parameters": {
        "url": "http://host.docker.internal:5174/api/social/tweet",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "text", "value": "={{ '✨ Nuevo contenido disponible\n\n' + $json.items[0].title + '\n\n🔗 ' + $json.items[0].url }}" },
            { "name": "media_url", "value": "={{ $json.preview_url }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "publish-telegram",
      "name": "Publicar en Telegram Channel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1050, 400],
      "parameters": {
        "url": "https://api.telegram.org/bot8875376383:AAG4dDoxdUfHqR7oIqW0lC4ygLxfzfg1EMA/sendPhoto",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "chat_id", "value": "@tu_canal" },
            { "name": "photo", "value": "={{ $json.preview_url }}" },
            { "name": "caption", "value": "={{ '🔥 Nuevo: ' + $json.items[0].title + '\n\n💰 $' + $json.items[0].price + ' MXN\n\n🔗 ' + $json.items[0].url }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "log-analytics",
      "name": "Registrar en Analytics (PostHog)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1250, 300],
      "parameters": {
        "url": "http://host.docker.internal:5174/api/analytics/event",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "event", "value": "content_promoted" },
            { "name": "properties", "value": "={{ {\n  'item_id': $json.items[0].id,\n  'title': $json.items[0].title,\n  'price': $json.items[0].price,\n  'platforms': ['twitter', 'telegram']\n} }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "no-content",
      "name": "No hay contenido nuevo",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [850, 400],
      "parameters": {}
    },
    {
      "id": "analytics-report",
      "name": "Reporte Semanal de Conversión",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 600],
      "parameters": {
        "rule": {
          "hour": 9,
          "minute": 0,
          "weekday": 1
        }
      }
    },
    {
      "id": "get-stats",
      "name": "Obtener Estadísticas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 600],
      "parameters": {
        "url": "http://host.docker.internal:5174/api/analytics/report/weekly",
        "method": "GET",
        "options": {}
      }
    },
    {
      "id": "send-report",
      "name": "Enviar Reporte por Telegram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [650, 600],
      "parameters": {
        "url": "https://api.telegram.org/bot8875376383:AAG4dDoxdUfHqR7oIqW0lC4ygLxfzfg1EMA/sendMessage",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "chat_id", "value": "5738935134" },
            { "name": "text", "value": "={{ '📊 Reporte Semanal\n\n' +\n'Contenido publicado: ' + $json.published + '\n' +\n'Vistas totales: ' + $json.views + '\n' +\n'Conversiones: ' + $json.sales + '\n' +\n'Revenue: $' + $json.revenue + ' MXN\n' +\n'Top producto: ' + $json.top_seller }}" },
            { "name": "parse_mode", "value": "HTML" }
          ]
        },
        "options": {}
      }
    }
  ],
  "connections": {
    "schedule-auto": { "main": [[ { "node": "fetch-content", "type": "main" } ]] },
    "fetch-content": { "main": [[ { "node": "check-new", "type": "main" } ]] },
    "check-new": {
      "main": [
        [{ "node": "preview-generator", "type": "main" }],
        [{ "node": "no-content", "type": "main" }]
      ]
    },
    "preview-generator": {
      "main": [
        [{ "node": "publish-twitter", "type": "main" }],
        [{ "node": "publish-telegram", "type": "main" }]
      ]
    },
    "publish-twitter": { "main": [[ { "node": "log-analytics", "type": "main" } ]] },
    "publish-telegram": { "main": [[ { "node": "log-analytics", "type": "main" } ]] },
    "analytics-report": { "main": [[ { "node": "get-stats", "type": "main" } ]] },
    "get-stats": { "main": [[ { "node": "send-report", "type": "main" } ]] }
  }
}
