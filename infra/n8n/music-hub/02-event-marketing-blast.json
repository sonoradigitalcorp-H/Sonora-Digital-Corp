            "index": 0
          }
        ]
      ]
    },
    "Merge Evento + Flyer": {
      "main": [
        [
          {
            "node": "Telegram — Blast Inicial al Artista",
            "type": "main",
            "index": 0
          },
          {
            "node": "Esperar 3 días",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Esperar 3 días": {
      "main": [
        [
          {
            "node": "Telegram — Reminder Blast",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "America/Hermosillo",
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
