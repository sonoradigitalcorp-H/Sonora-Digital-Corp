#!/usr/bin/env node
/**
 * ═══════════════════════════════════════════════════════════════
 * sdc — Sonora Digital Corp Unified CLI v2.0
 * ═══════════════════════════════════════════════════════════════
 * Un solo comando para todo el ecosistema.
 * Reemplaza 61 scripts legacy con subcomandos organizados.
 *
 * Uso: sdc <comando> [subcomando] [args]
 *
 * Comandos:
 *   sdc                          Estado general del ecosistema
 *   sdc agent list|spawn|kill    Gestión de agentes
 *   sdc mcp status|tools|auth    MCP Gateway
 *   sdc adk init|build|register  Agent Development Kit
 *   sdc capability list|resolve  Capability Registry
  sdc plugin list|install|search|create  Plugin Marketplace
  sdc swarm run|list            Swarm de agentes
  sdc learning stats            Self-Learning stats
 *   sdc skill list|run           Skills
 *   sdc event emit|tail          Eventos
 *   sdc score                    Enterprise Score
 *   sdc finops                   FinOps
 *   sdc backup                   Backup completo
 *   sdc health                   Healthcheck
 *   sdc legacy                   Scripts legacy (transición)
 * ═══════════════════════════════════════════════════════════════
 */

const path = require('path');
const fs = require('fs');
const { execSync } = require('child_process');

const SDK_PATH = path.join(__dirname, '..', 'sdk', 'sonora-client.js');
const SonoraSDK = require(SDK_PATH);

const sdk = new SonoraSDK({
  clientId: process.env.SONORA_CLIENT_ID || 'sdc-core',
  clientSecret: process.env.SONORA_CLIENT_SECRET || '',
  gatewayPort: parseInt(process.env.SONORA_GATEWAY_PORT || '18989'),
});

const SCRIPTS_DIR = path.join(__dirname, '..', '..', 'scripts');
const SDC_DIR = path.join(__dirname, '..', '..');

async function main() {
  const args = process.argv.slice(2);
  const cmd = args[0];

  if (!cmd || cmd === 'status' || cmd === 'help') {
    return showHelp();
  }

  try {
    switch (cmd) {
      case 'agent':    return await agentCmd(args.slice(1));
      case 'mcp':      return await mcpCmd(args.slice(1));
      case 'adk':      return await adkCmd(args.slice(1));
      case 'capability': return await capabilityCmd(args.slice(1));
        case 'skill':    return await skillCmd
      case 'plugin':   return await pluginCmd
      case 'swarm':    return await swarmCmd
      case 'learning': return await learningCmd(args.slice(1));
      case 'event':    return await eventCmd(args.slice(1));
      case 'score':    return await scoreCmd();
      case 'finops':   return await finopsCmd();
      case 'backup':   return await backupCmd();
      case 'health':   return await healthCmd();
      case 'legacy':   return await legacyCmd(args.slice(1));
      case 'eval':     return await evalCmd(args.slice(1));
      default:
        console.log(`❌ Comando desconocido: ${cmd}\n`);
        showHelp();
    }
  } catch (e) {
    console.error('❌ Error:', e.message);
    process.exit(1);
  }
}

