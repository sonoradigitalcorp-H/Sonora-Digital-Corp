{
  "$schema": "https://opencode.ai/config.json",
  "username": "Mystic — SDC Agent OS v1.0",
  "model": "opencode/deepseek-v4-flash-free",
  "small_model": "opencode/mimo-v2.5-free",
  "default_agent": "mystic",
  "shell": "/bin/bash",
  "logLevel": "DEBUG",
  "instructions": [
    "AGENTS.md",
    "docs/SESSION-20260713-SDC-AGENT-OS.md"
  ],

  "skills": {
    "paths": [
      ".opencode/skills",
      "skills"
    ]
  },

  "agent": {
    "mystic": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Mystic — operador del SDC Agent OS. Construye empresas agent-native.",
      "permission": {
        "read": "allow",
        "edit": "ask",
        "bash": "ask",
        "glob": "allow",
        "grep": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "task": "allow"
      }
    },
    "builder": {
      "mode": "subagent",
      "model": "opencode/north-mini-code-free",
      "description": "Builder — ejecuta implementación siguiendo SDD pipeline",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": {
          "git *": "allow",
          "pip *": "allow",
          "npm *": "allow",
          "*": "ask"
        }
      }
    },
    "explore": {
      "mode": "subagent",
      "description": "Explorador de código y búsqueda",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "deny"
      }
    }
  },

  "mcp": {
    "sonora-mcp": {
      "type": "remote",
      "url": "http://127.0.0.1:8180",
      "enabled": true,
      "description": "SDC MCP Gateway — 53 tools (Hasura, Engram, Supabase, OmniVoice, FAL, MP, RAG)"
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=jibalggzudkflwzdndqz",
      "enabled": true,
      "headers": {
        "x-supabase-anon-key": "sb_publisible_2n9gZ64cIbtrhK9s3hClgQ_chzhTtjK",
        "x-supabase-service-key": "{env:SUPABASE_SERVICE_KEY}"
      },
      "description": "Supabase MCP — DB directa"
    }
  },

  "command": {
    "status": {
      "description": "Estado completo del sistema",
      "template": "Ejecuta healthcheck completo: MCP Gateway, Hasura, Redis, Qdrant, Docker, Systemd"
    },
    "design": {
      "description": "Generar componentes UI premium con shadcn/ui, three.js, Tailwind",
      "template": "Usa el skill design en skills/design/SKILL.md. Genera componentes React/TypeScript individuales con shadcn/ui, @react-three/drei, framer-motion, y Tailwind CSS. $ARGUMENTS",
      "agent": "mystic"
    },
    "gsd": {
      "description": "Get Shit Done — flujo completo de implementación",
      "template": "GSD: 1) Estado actual 2) Qué hacer 3) Plan 4) Ejecutar 5) Verificar 6) Documentar",
      "agent": "builder"
    },
    "crear": {
      "description": "Crear empresa agent-native completa",
      "template": "Usa el skill creator en skills/creator/SKILL.md. Crea tenant, 6 agentes, smart app. $ARGUMENTS",
      "agent": "mystic"
    },
    "plan": {
      "description": "Planning Gate — descompone en tareas",
      "template": "Planifica siguiendo SDD pipeline: Research→Spec→Design→Tasks→Apply→Verify→Archive. $ARGUMENTS"
    }
  },

  "references": {
    "ablueprint": {
      "path": "tenants/sdc/blueprint",
      "description": "SDC Smart App Blueprint — hooks y componentes reutilizables"
    },
    "core": {
      "path": "core",
      "description": "SDC Core — infraestructura del sistema"
    },
    "agents": {
      "path": "agents",
      "description": "Registro de agentes por tenant"
    }
  }
}
