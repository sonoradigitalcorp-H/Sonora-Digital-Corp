# Mystika API — Environment Variables

PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/mystika
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mystika
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MYSTERIA_PRICE_ID=
STRIPE_RITUAL_PRICE_ID=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_MYSTERIA_PREAPPROVAL_ID=
MP_RITUAL_PREAPPROVAL_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# Video Storage
VIDEO_STORAGE_PATH=/data/videos/mystika

# AI Chat
OPENROUTER_API_KEY=
LILITH_PROMPT_ID=

# Frontend
FRONTEND_URL=http://localhost:3000
