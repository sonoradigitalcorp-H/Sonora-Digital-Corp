# Lobe Chat Config — Mystik AI
# https://lobehub.com/docs/self-hosting/environment-variables

# Branding
LOBE_SITE_TITLE=Mystik AI
LOBE_SITE_DESCRIPTION=Tu asistente de ventas inteligente
LOBE_THEME_PRIMARY_COLOR=#FF6B35
LOBE_NAV_COLOR=#1a1a2e
LOBE_BRANDING_LOGO=https://mystik.sonoradigitalcorp.com/logo.svg

# LLM — Ollama DeepSeek
LLM_VISION=1
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_LIST=deepseek-r1:7b

# Plugins — Mystik backend
PLUGINS_ENABLED=1
PLUGINS_URL=http://host.docker.internal:5200/api/plugins

# Auth
AUTH_ENABLED=1
NEXT_AUTH_SECRET=mystik-sdc-secret-2026

# Features
FEATURE_VOICE_UPLOAD=1
FEATURE_ARTIFACTS=1
FEATURE_TOPIC=1
FEATURE_SAVE_CHAT_TO_PDF=1
